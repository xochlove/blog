/* 1. Fondo y fuente caótica */
body {
  background-color: #000; /* Fondo oscuro */
  background-image: url('tu-textura-repetitiva.gif'); /* Patrón loco */
  font-family: "Comic Sans MS", cursive; /* Fuente obligatoria [citation:12] */
  color: #fff;
}

/* 2. Cajas de contenido con borde "bevel" (efecto 3D) */
.caja-perfil {
  background-color: #111;
  border: 3px solid #ff00ff; /* Borde neón */
  box-shadow: 5px 5px 0px #00ffff; /* Sombra sólida estilo retro [citation:11] */
  padding: 15px;
}

/* 3. Estilo de los enlaces (neones) */
a {
  color: #ff69b4;
  text-decoration: none;
}
a:hover {
  color: #00ffcc;
  text-decoration: underline; /* Subrayado al pasar el mouse */
}